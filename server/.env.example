# Server environment (copy to .env)
# ------------------------------------------------------------
# MongoDB
# Local example: mongodb://127.0.0.1:27017/talenttrade
# Atlas example: mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
MONGO_URI=

# Server
PORT=5001
NODE_ENV=development

# Auth
JWT_SECRET=

# CORS / Frontend URLs (used in server.js + email templates)
FRONTEND_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000
# Optional: additional allowed origins, comma-separated
ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email (Resend)
RESEND_API_KEY=
# Optional override (default: onboarding@resend.dev)
RESEND_FROM=

# AI (Groq)
GROQ_API_KEY=

# Uploads (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
